{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt",
    "watchPatterns": [
      "app/**",
      "requirements.txt",
      "pyproject.toml"
    ]
  },
  "deploy": {
    "startCommand": "python -m uvicorn main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "environmentVariables": {
    "DATABASE_URL": {
      "description": "PostgreSQL数据库连接URL",
      "generator": "postgresql"
    },
    "REDIS_URL": {
      "description": "Redis连接URL",
      "generator": "redis"
    },
    "TUSHARE_TOKEN": {
      "description": "Tushare Pro API Token",
      "required": true
    },
    "AI_PROVIDER": {
      "description": "AI提供商 (mock, deepseek, openai, glm, baidu)",
      "default": "mock"
    },
    "DEEPSEEK_API_KEY": {
      "description": "DeepSeek API密钥",
      "required": false
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API密钥",
      "required": false
    },
    "ENVIRONMENT": {
      "description": "环境变量",
      "default": "production"
    },
    "CORS_ORIGINS": {
      "description": "CORS允许的来源",
      "default": "https://finscreener.vercel.app,http://localhost:3000"
    },
    "LOG_LEVEL": {
      "description": "日志级别",
      "default": "INFO"
    },
    "CACHE_TTL": {
      "description": "缓存过期时间（秒）",
      "default": "300"
    }
  },
  "services": [
    {
      "name": "finscreener-api",
      "type": "web",
      "source": {
        "dir": "backend"
      },
      "domains": [
        {
          "name": "finscreener-api.up.railway.app"
        }
      ]
    },
    {
      "name": "postgres",
      "type": "postgresql",
      "plan": "starter"
    },
    {
      "name": "redis",
      "type": "redis",
      "plan": "starter"
    }
  ],
  "checks": {
    "health": {
      "type": "http",
      "path": "/health",
      "interval": 30,
      "timeout": 10,
      "attempts": 3
    },
    "readiness": {
      "type": "http",
      "path": "/api/health",
      "interval": 30,
      "timeout": 10,
      "attempts": 3
    }
  },
  "observability": {
    "logs": {
      "retention": "30d"
    },
    "metrics": {
      "enabled": true
    }
  }
}