# FinScreener 环境变量配置示例

# ====================
# 基础配置
# ====================
DEBUG=true
ENVIRONMENT=development

# ====================
# 服务器配置
# ====================
HOST=0.0.0.0
PORT=8000

# ====================
# 数据库配置
# ====================
# PostgreSQL 示例
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/finscreener

# SQLite 开发用（可选）
# DATABASE_URL=sqlite+aiosqlite:///./finscreener.db

# ====================
# Redis配置
# ====================
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_POOL_TIMEOUT=30

# ====================
# 数据源配置
# ====================
# Tushare Pro Token (必需)
# 注册地址: https://tushare.pro
TUSHARE_TOKEN=your_tushare_token_here

AKSHARE_ENABLED=true

# ====================
# AI配置
# ====================
AI_PROVIDER=deepseek  # deepseek, openai, glm, baidu

# DeepSeek API (推荐免费使用)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# GLM API (智谱AI)
GLM_API_KEY=your_glm_api_key_here

# 百度文心一言 API
BAIDU_API_KEY=your_baidu_api_key_here

# ====================
# 缓存配置
# ====================
CACHE_ENABLED=true
CACHE_TTL=300  # 5分钟
CACHE_MAX_SIZE=1000

# ====================
# 限流配置
# ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # 秒

# ====================
# 安全配置
# ====================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================
# 日志配置
# ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ====================
# 静态文件配置
# ====================
STATIC_FILES_ENABLED=false
STATIC_FILES_DIR=static

# ====================
# 数据同步配置
# ====================
DATA_SYNC_ENABLED=true
DATA_SYNC_INTERVAL=300  # 5分钟
DATA_SYNC_BATCH_SIZE=100

# ====================
# 监控配置
# ====================
# Sentry (错误监控)
SENTRY_DSN=your_sentry_dsn_here

PROMETHEUS_ENABLED=false

# ====================
# 前端配置
# ====================
VITE_API_URL=http://localhost:8000/api