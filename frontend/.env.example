# 前端环境变量

# API地址
VITE_API_URL=http://localhost:8000/api

# 应用名称
VITE_APP_NAME=FinScreener

# 版本
VITE_APP_VERSION=1.0.0

# 是否启用调试模式
VITE_DEBUG=true

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=false

# 是否启用错误追踪
VITE_ENABLE_ERROR_TRACKING=false

# Sentry DSN (如果需要错误监控)
VITE_SENTRY_DSN=

# Google Analytics ID (如果需要分析)
VITE_GA_ID=